# ── Production (required for real customers) ──
# Deploy your app with HTTPS, then set your public URL:
# APP_BASE_URL=https://agents.yourcompany.com
# OAUTH_REDIRECT_URI=https://agents.yourcompany.com/api/gmail/callback
# YOUTUBE_OAUTH_REDIRECT_URI=https://agents.yourcompany.com/api/youtube/callback

# ── Render (Aivana) ──
# APP_BASE_URL=https://aivana-65kg.onrender.com
# OAUTH_REDIRECT_URI=https://aivana-65kg.onrender.com/api/gmail/callback
# YOUTUBE_OAUTH_REDIRECT_URI=https://aivana-65kg.onrender.com/api/youtube/callback

# ── Local dev with tunnel (if localhost callback does not work) ──
# Run: ngrok http 8001
# Then paste the ngrok HTTPS URL:
# APP_BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.app
# OAUTH_REDIRECT_URI=https://YOUR-SUBDOMAIN.ngrok-free.app/api/gmail/callback

# ── Local dev (only works on your machine) ──
APP_BASE_URL=http://localhost:8001
OAUTH_REDIRECT_URI=

APP_SECRET=change-me-in-production-use-long-random-string
GOOGLE_CLIENT_SECRETS_FILE=credentials/client_secret.json
YOUTUBE_CLIENT_SECRETS_FILE=credentials/youtube_client_secret.json
# Heroku: separate JSON env vars for Gmail vs YouTube clients
# GOOGLE_CLIENT_SECRETS_JSON={"web":{"client_id":"...","client_secret":"..."}}
# YOUTUBE_CLIENT_SECRETS_JSON={"web":{"client_id":"...","client_secret":"..."}}

# ── Telecaller (Twilio) — optional; simulates calls when unset ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1234567890

# ── Mailer (SMTP) — optional; simulates sends when unset ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true

# ── Planner LLM (OpenAI) — recommended for smart customer triage ──
# OPENAI_API_KEY=sk-...
# PLANNER_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── CreatorOS — Gemini Veo intro videos (never commit real keys) ──
# GEMINI_API_KEY=
# GEMINI_PROJECT_ID=778857877018
# VEO_MODEL=veo-3.1-fast-generate-preview
# CONTENT_HUMAN_IN_LOOP=true
